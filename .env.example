# Canonical Vercel + Neon launch contract for Synesthesia Machine.
# Copy the keys you need into .env.local for local work. Do not commit real values.

# -----------------------------------------------------------------------------
# Deploy-required runtime contract
# Required for DEPLOYMENT_ENV_MODE=deployed-runtime and for any real Neon-backed app.
# Optional in local proof mode; if omitted locally, DB-backed routes fall back to the
# branded unavailable/no-DB experience instead of pretending to work.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
ADMIN_SECRET="replace-with-long-random-admin-secret"
CRON_SECRET="replace-with-long-random-cron-secret"

# -----------------------------------------------------------------------------
# Operator / verification contract
# Used by deployment verification tooling and operator workflows, not by the public
# browser bundle itself. Keep these out of client-visible code.
# -----------------------------------------------------------------------------
SYNESTHESIA_PUBLIC_BASE_URL="https://your-vercel-deployment.vercel.app"

# -----------------------------------------------------------------------------
# Optional observability contract
# Safe to omit. When present, values must be real and non-blank.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY="phc_your_project_key"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_SENTRY_DSN="https://public@example.ingest.sentry.io/0"
SENTRY_DSN="https://server@example.ingest.sentry.io/0"
SENTRY_AUTH_TOKEN="sntrys_your_auth_token"
NEXT_PUBLIC_OBSERVABILITY_SAMPLE_RATE="1"
