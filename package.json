{
  "name": "art-synesthesia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "deploy:preflight": "node --experimental-strip-types --input-type=module -e \"import { runDeploymentPreflightCli } from './src/lib/deployment/env.ts'; runDeploymentPreflightCli(process.env.DEPLOYMENT_ENV_MODE);\"",
    "deploy:build": "npm run deploy:preflight && next build",
    "deploy:migrate": "npm run db:migrate",
    "deploy:smoke": "node scripts/verify-deployment.mjs",
    "db:migrate": "node --experimental-strip-types src/db/migrate.ts",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@sentry/nextjs": "^10.46.0",
    "afinn-165": "^2.0.2",
    "cheerio": "^1.2.0",
    "culori": "^4.0.2",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.45.0",
    "geist": "^1.7.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "obscenity": "^0.4.0",
    "papaparse": "^5.5.3",
    "posthog-js": "^1.363.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "seedrandom": "^3.0.5",
    "simple-statistics": "^7.8.8",
    "simplex-noise": "^4.0.3",
    "syllable": "^5.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/culori": "^4.0.1",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
